<?xml version="1.0" encoding="utf-8"?>
<robot name="two_cube_connector_via_spheres">

  <!-- ================= Cube 1 (Body Link 1) ================= -->
  <link name="body_link">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.025" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.025"/>
    </inertial>
  </link>

  <!-- Cube 1 Spheres -->
  <!-- Top Sphere -->
  <joint name="top_sphere_joint_body" type="fixed">
    <parent link="body_link"/>
    <child link="top_sphere"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>
  <link name="top_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Bottom Sphere -->
  <joint name="bottom_sphere_joint_body" type="fixed">
    <parent link="body_link"/>
    <child link="bottom_sphere"/>
    <origin xyz="0 0 -0.05" rpy="0 0 0"/>
  </joint>
  <link name="bottom_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Front Sphere -->
  <joint name="front_sphere_joint_body" type="fixed">
    <parent link="body_link"/>
    <child link="front_sphere"/>
    <origin xyz="0 0.05 0" rpy="0 0 0"/>
  </joint>
  <link name="front_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Back Sphere -->
  <joint name="back_sphere_joint_body" type="fixed">
    <parent link="body_link"/>
    <child link="back_sphere"/>
    <origin xyz="0 -0.05 0" rpy="0 0 0"/>
  </joint>
  <link name="back_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Left Sphere -->
  <joint name="left_sphere_joint_body" type="fixed">
    <parent link="body_link"/>
    <child link="left_sphere"/>
    <origin xyz="-0.05 0 0" rpy="0 0 0"/>
  </joint>
  <link name="left_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Right Sphere (used as connection point) -->
  <joint name="right_sphere_joint_body" type="fixed">
    <parent link="body_link"/>
    <child link="right_sphere"/>
    <origin xyz="0.05 0 0" rpy="0 0 0"/>
  </joint>
  <link name="right_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- ================= Connector: Dummy Square Link ================= -->
  <!-- This black box is the dummy connector -->
  <joint name="square_connector_joint1" type="fixed">
    <parent link="right_sphere"/>
    <child link="link_square"/>
    <!-- Adjust this origin to position the square connector relative to Cube 1 -->
    <origin xyz="0.02 0 0" rpy="0 0 0"/>
  </joint>
  <link name="link_square">
    <visual>
      <geometry>
        <box size="0.07 0.07 0.07"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.07 0.07 0.07"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.003"/>
    </inertial>
  </link>

  <!-- ================= Cube 2 (Body Link 2) ================= -->
  <link name="body_link2">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.025" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.025"/>
    </inertial>
  </link>

  <!-- Cube 2 Spheres (except left sphere) -->
  <!-- Top Sphere -->
  <joint name="top_sphere_joint_body2" type="fixed">
    <parent link="body_link2"/>
    <child link="top_sphere2"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>
  <link name="top_sphere2">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Bottom Sphere -->
  <joint name="bottom_sphere_joint_body2" type="fixed">
    <parent link="body_link2"/>
    <child link="bottom_sphere2"/>
    <origin xyz="0 0 -0.05" rpy="0 0 0"/>
  </joint>
  <link name="bottom_sphere2">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Front Sphere -->
  <joint name="front_sphere_joint_body2" type="fixed">
    <parent link="body_link2"/>
    <child link="front_sphere2"/>
    <origin xyz="0 0.05 0" rpy="0 0 0"/>
  </joint>
  <link name="front_sphere2">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Back Sphere -->
  <joint name="back_sphere_joint_body2" type="fixed">
    <parent link="body_link2"/>
    <child link="back_sphere2"/>
    <origin xyz="0 -0.05 0" rpy="0 0 0"/>
  </joint>
  <link name="back_sphere2">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Right Sphere -->
  <joint name="right_sphere_joint_body2" type="fixed">
    <parent link="body_link2"/>
    <child link="right_sphere2"/>
    <origin xyz="0.05 0 0" rpy="0 0 0"/>
  </joint>
  <link name="right_sphere2">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Note: Do NOT attach a left sphere directly to body_link2.
       Instead, we use the left sphere as the connection point for the dummy connector. -->
  <link name="left_sphere2">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- ========== Connector Joint from Dummy Square to Cube2's Left Sphere ========== -->
  <joint name="square_connector_joint2" type="fixed">
    <parent link="link_square"/>
    <child link="left_sphere2"/>
    <!-- Adjust this origin so that the connector reaches the proper position relative to Cube 2 -->
    <origin xyz="0.02 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ========== Attach Cube2 to its Left Sphere ========== -->
  <joint name="cube2_connection_joint" type="fixed">
    <parent link="left_sphere2"/>
    <child link="body_link2"/>
    <!-- Adjust the origin so that Cube2 is offset relative to its left sphere -->
    <origin xyz="0.05 0 0" rpy="0 0 0"/>
  </joint>

</robot>
