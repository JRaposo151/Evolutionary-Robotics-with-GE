<?xml version="1.0"?>
<robot name="BODY_LINK">
  <link name="body_link">

    <!-- FRONT face (red) -->
    <visual>
      <origin xyz="0 0 0.023" rpy="0 0 0"/>
      <geometry>
        <box size="0.046 0.046 0.001"/>
      </geometry>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>

    <!-- BACK face (green) -->
    <visual>
      <origin xyz="0 0 -0.023" rpy="0 0 0"/>
      <geometry>
        <box size="0.046 0.046 0.001"/>
      </geometry>
      <material name="green">
        <color rgba="0.0 1.0 0.0 1.0"/>
      </material>
    </visual>

    <!-- RIGHT face (blue) -->
    <visual>
      <origin xyz="0.023 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <box size="0.046 0.046 0.001"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>

    <!-- LEFT face (yellow) -->
    <visual>
      <origin xyz="-0.023 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <box size="0.046 0.046 0.001"/>
      </geometry>
      <material name="yellow">
        <color rgba="1.0 1.0 0.0 1.0"/>
      </material>
    </visual>

    <!-- TOP face (cyan) -->
    <visual>
      <origin xyz="0 0.023 0" rpy="1.5708 0 0"/>
      <geometry>
        <box size="0.046 0.046 0.001"/>
      </geometry>
      <material name="cyan">
        <color rgba="0.0 1.0 1.0 1.0"/>
      </material>
    </visual>

    <!-- BOTTOM face (magenta) -->
    <visual>
      <origin xyz="0 -0.023 0" rpy="1.5708 0 0"/>
      <geometry>
        <box size="0.046 0.046 0.001"/>
      </geometry>
      <material name="magenta">
        <color rgba="1.0 0.0 1.0 1.0"/>
      </material>
    </visual>

    <!-- Collision and Inertia (single cube) -->
    <collision>
      <geometry>
        <box size="0.046 0.046 0.046"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0000353" ixy="0.0" ixz="0.0"
               iyy="0.0000353" iyz="0.0"
               izz="0.0000353"/>
    </inertial>

  </link>

  <!-- Back Sphere (negative Y direction) -->
  <joint name="joint_1" type="fixed">
    <parent link="body_link"/>
    <child link="back_sphere"/>
    <origin xyz="0 -0.023 0" rpy="1.55 0 0"/>
  </joint>

  <link name="back_sphere">
    <visual>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.004"/>
      <inertia ixx="1.7e-07" ixy="0.0" ixz="0.0"
      iyy="1.7e-07" iyz="0.0"
      izz="1.7e-07"/>
    </inertial>
  </link>


  <joint name="joint_1" type="fixed">
    <parent link="back_sphere"/>
    <child link="link_square"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>


<link name="link_square">
  <visual>
    <geometry>
      <box size="0.03 0.03 0.03" /> <!-- Length, width, and height of the box -->
    </geometry>
    <material name="black">
      <color rgba="0.0 0.0 0.0 1.0" /> <!-- RGBA color for the link -->
    </material>
  </visual>
  <collision>
    <geometry>
      <box size="0.03 0.03 0.03" /> <!-- Same dimensions as the visual -->
    </geometry>
  </collision>
  <inertial>
    <mass value="0.05" /> <!-- Mass of the link -->
  <inertia 
    ixx="7.5e-06" ixy="0.0" ixz="0.0"
    iyy="7.5e-06" iyz="0.0"
    izz="7.5e-06" />
  </inertial>
</link>


  <joint name="joint_2" type="fixed">
    <parent link="link_square"/>
    <child link="a"/>
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
  </joint>



  <link name="a">
    <visual>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 55.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.004"/>
    <inertia ixx="1.7e-07" ixy="0.0" ixz="0.0"
      iyy="1.7e-07" iyz="0.0"
      izz="1.7e-07"/>
    </inertial>
  </link>



    <joint name="joint_1" type="fixed">
    <parent link="a"/>
    <child link="limb_link"/>
    <origin xyz="0 0 0.022" rpy="0 0 3.15"/>
  </joint>


  <link name="limb_link">
    <visual>
      <geometry>
        <cylinder length="0.045" radius="0.015"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.045" radius="0.015"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
    <inertia ixx="6.875e-06" ixy="0.0" ixz="0.0"
    iyy="6.875e-06" iyz="0.0"
    izz="5.625e-06"/>   
    </inertial>
    </link>



  <!-- Joint for Limb -->
  <joint name="joint_2" type="fixed">
    <parent link="limb_link"/>
    <child link="limb_small_link_robot"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>



<link name="limb_small_link_robot">
    <visual>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.006"/>
    <inertia ixx="0.00098" ixy="0.0" ixz="0.0" iyy="0.00098" iyz="0.0" izz="0.00098"/>
    </inertial>
  </link>





</robot>