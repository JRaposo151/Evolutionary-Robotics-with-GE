<?xml version="1.0"?>
<robot name="B_JOINT_REVO">

<joint name="joint_1" type="revolute">
    <parent link=""/>
    <child link="auxiliar"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="1.0" velocity="1.0"/>
  </joint>


  <link name="auxiliar">
    <visual>
      <geometry>
        <cylinder length="0.07" radius="0.05"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0025" ixy="0.0" ixz="0.0" iyy="0.0025" iyz="0.0" izz="0.0025"/>
    </inertial>
  </link>



  <joint name="joint_2" type="fixed">
    <parent link="auxiliar"/>
    <child link="bottom_sphere"/>
    <origin xyz="0 0.05 0" rpy="0 0 0"/>
  </joint>

  <link name="extra_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0025" ixy="0.0" ixz="0.0" iyy="0.0025" iyz="0.0" izz="0.0025"/>
    </inertial>
  </link>

  <joint name="joint_3" type="fixed">
    <parent link="bottom_sphere"/>
    <child link=""/>
    <!-- Adjust the origin so that Cube2 is offset relative to its left sphere -->
    <origin xyz="0 0.05 0" rpy="0 0 0"/>
  </joint>

</robot>