<?xml version="1.0"?>
<robot name="B_JOINT_CONTI">

<joint name="joint_1" type="continuous">
    <parent link="back_sphere"/>
    <child link="auxiliar"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="1.0" velocity="1.0" rpy="0 3.15 0" />
  </joint>

  <link name="auxiliar">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.04" radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05" /> <!-- Mass of the link -->
  <inertia 
    ixx="7.5e-06" ixy="0.0" ixz="0.0"
    iyy="7.5e-06" iyz="0.0"
    izz="7.5e-06" />
  </inertial>
  </link>




  <joint name="joint_2" type="fixed">
    <parent link="auxiliar"/>
    <child link="body_link2"/>
    <origin xyz="0 0 -0.035" rpy="0 0 0"/>
  </joint>

</robot>


