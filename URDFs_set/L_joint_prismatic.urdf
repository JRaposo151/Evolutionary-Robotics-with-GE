<?xml version="1.0"?>
<robot name="prismatic_joint">
  <joint name="prismatic_joint" type="prismatic">
    <parent link="top_attachment"/>
    <child link="bottom_attachment"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.05" effort="1.0" velocity="0.5"/>
  </joint>
</robot>
