<?xml version="1.0"?>
<robot name="Body_link_robot">

  <!-- Body Link -->
  <link name="body_link">


  <!-- Cylinder for the main body -->
    <visual>
      <geometry>
        <cylinder length="0.0375" radius="0.01125"/>
      </geometry>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>

    <collision>
     <!-- Cylinder collision at the top -->
      <geometry>
        <cylinder length="0.0375" radius="0.01125"/>
      </geometry>
    </collision>

<!-- ################################################################ -->

<!-- Sphere at the top -->
    <visual>
      <geometry>
        <sphere radius="0.01125"/>
      </geometry>
      <origin xyz="0 0 0.0175" rpy="0 0 0"/>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>

     <collision>
      <!-- Sphere collision at the top -->
      <geometry>
        <sphere radius="0.01125"/>
      </geometry>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
    </collision>

<!-- ################################################################ -->


<!-- Sphere at the bottom -->
    <visual>
      <geometry>
        <sphere radius="0.01125"/>
      </geometry>
      <origin xyz="0 0 -0.0175" rpy="0 0 0"/>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>

    <collision>
      <!-- Sphere collision at the bottom -->
      <geometry>
        <sphere radius="0.01125"/>
      </geometry>
      <origin xyz="0 0 -0.015" rpy="0 0 0"/>
    </collision>


    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

<!-- Universal Attachment Points -->
  <link name="top_attachment"/>
  <joint name="top_joint" type="fixed">
    <parent link="body_link"/>
    <child link="top_attachment"/>
    <origin xyz="0 0 0.0175" rpy="0 0 0"/>
  </joint>



  <joint name="revolute_joint" type="revolute">
    <parent link="top_attachment"/>
    <child link="top_attachment2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="1.0" velocity="1.0"/>
  </joint>







  <!-- Limb Link -->
  <link name="limb_link">

      <!-- Attachment Points -->
  <link name="top_attachment2"/>
  <joint name="top_joint" type="fixed">
    <parent link="limb_link"/>
    <child link="top_attachment"/>
    <origin xyz="0 0 0.018" rpy="0 0 0"/>
  </joint>

  <link name="bottom_attachment"/>
  <joint name="bottom_joint" type="fixed">
    <parent link="limb_link"/>
    <child link="bottom_attachment"/>
    <origin xyz="0 0 -0.018" rpy="0 0 0"/>
  </joint>


    <visual>
      <!-- Cylinder for the main body -->
      <geometry>
        <cylinder length="0.0375" radius="0.00625"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <cylinder length="0.03" radius="0.01"/>
      </geometry>
    </collision>


    <!-- ################################################################ -->


    <visual>
      <!-- Sphere at the top -->
      <geometry>
        <sphere radius="0.00625"/>
      </geometry>
      <origin xyz="0 0 0.018" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>


     <collision>
      <!-- Sphere collision at the top -->
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <origin xyz="0 0 0.015" rpy="0 0 0"/>
    </collision>

    <!-- ################################################################ -->


    <visual>
      <!-- Sphere at the bottom -->
      <geometry>
        <sphere radius="0.00625"/>
      </geometry>
      <origin xyz="0 0 -0.018" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>

    <collision>
      <!-- Sphere collision at the bottom -->
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <origin xyz="0 0 -0.015" rpy="0 0 0"/>
    </collision>

    <!-- ################################################################ -->



    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>




</robot>