<?xml version="1.0"?>
<robot name="L_JOINT_FIX">

<joint name="joint_1" type="fixed">
    <parent link=""/>
    <child link="link_square"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

<link name="link_square">
  <visual>
    <geometry>
      <box size="0.04 0.04 0.04" /> <!-- Length, width, and height of the box -->
    </geometry>
    <material name="blue">
      <color rgba="0.0 0.0 0.0 1.0" /> <!-- RGBA color for the link -->
    </material>
  </visual>
  <collision>
    <geometry>
      <box size="0.04 0.04 0.04" /> <!-- Same dimensions as the visual -->
    </geometry>
  </collision>
  <inertial>
    <mass value="1.0" /> <!-- Mass of the link -->
  <inertia ixx="0.00027" ixy="0.0" ixz="0.0" iyy="0.00027" iyz="0.0" izz="0.00027"/>  
  </inertial>
</link>


  <joint name="joint_2" type="fixed">
    <parent link=""/>
    <child link=""/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

</robot>