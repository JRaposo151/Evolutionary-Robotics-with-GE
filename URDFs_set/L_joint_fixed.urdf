<?xml version="1.0"?>
<robot name="L_JOINT_FIX">

<joint name="continuous_joint" type="fixed">
    <parent link="body_joint_link"/>
    <child link="link_square"/>
    <origin xyz="0 0.03 0" rpy="0.06 0 0"/>
  </joint>

<link name="link_square">
  <visual>
    <geometry>
      <box size="0.05 0.05 0.05" /> <!-- Length, width, and height of the box -->
    </geometry>
    <material name="blue">
      <color rgba="0.0 0.0 0.0 1.0" /> <!-- RGBA color for the link -->
    </material>
  </visual>
  <collision>
    <geometry>
      <box size="0.05 0.05 0.05" /> <!-- Same dimensions as the visual -->
    </geometry>
  </collision>
  <inertial>
    <mass value="1.0" /> <!-- Mass of the link -->
    <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.003" /> <!-- Moment of inertia -->
  </inertial>
</link>


  <joint name="fixed_joint" type="fixed">
    <parent link="link_square"/>
    <child link="limb_joint_bottom_blue_link"/>
    <origin xyz="0 0.2 0.005" rpy="1.6 0 0"/>
  </joint>

</robot>