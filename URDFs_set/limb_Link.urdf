<?xml version="1.0"?>
<robot name="Limb_LINK">


<link name="">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 55.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0025" ixy="0.0" ixz="0.0" iyy="0.0025" iyz="0.0" izz="0.0025"/>
    </inertial>
  </link>



    <joint name="fixed_joint_" type="fixed">
    <parent link=""/>
    <child link="limb_link"/>
    <origin xyz="0 0 0.09" rpy="0 0 0"/>
  </joint>

   <!-- Limb Link -->
  <link name="limb_link">
    <visual>
      <geometry>
        <cylinder length="0.1875" radius="0.03125"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.1875" radius="0.03125"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.0125" ixy="0.0" ixz="0.0" iyy="0.0125" iyz="0.0" izz="0.0125"/>
    </inertial>
  </link>


    

   <!-- Joint for Limb -->
  <joint name="bot_sphere_joint_limb" type="fixed">
    <parent link="limb_link"/>
    <child link="limb_joint_bottom_blue_link"/>
    <origin xyz="0 0 0.09" rpy="0 0 0"/>
  </joint>


  <!-- Limb Joint Bottom -->
  <link name="limb_joint_bottom_blue_link">
    <visual>
      <geometry>
        <sphere radius="0.03125"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.03125"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.0125" ixy="0.0" ixz="0.0" iyy="0.0125" iyz="0.0" izz="0.0125"/>
    </inertial>
  </link>
  
</robot>


