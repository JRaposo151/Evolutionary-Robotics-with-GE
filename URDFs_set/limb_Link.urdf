<?xml version="1.0"?>
<robot name="Limb_LINK">


<link name="">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 55.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
    <inertia ixx="0.00008" ixy="0.0" ixz="0.0" iyy="0.00008" iyz="0.0" izz="0.00008"/>    
    </inertial>
  </link>



    <joint name="joint_1" type="fixed">
    <parent link="aux_sphere"/>
    <child link="limb_link"/>
    <origin xyz="0 0 0.09" rpy="0 0 3.15"/>
  </joint>

   <!-- Limb Link -->
  <link name="limb_link">
    <visual>
      <geometry>
        <cylinder length="0.1875" radius="0.03125"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
    <!-- Additional visual: red vertical stripe on the cylinder's surface -->
    <visual>
      <!-- Offset by the cylinder's radius so it sits on the outer surface -->
      <origin xyz="0.03125 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- A thin box: width and depth very small, height equal to the cylinder's length --> 
        <box size="0.003 0.003 0.1875"/>
      </geometry>
      <material name="red_line">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.1875" radius="0.03125"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.5"/>
    <inertia ixx="0.00794" ixy="0.0" ixz="0.0" iyy="0.00794" iyz="0.0" izz="0.00122"/>    
    </inertial>
  </link>


    

   <!-- Joint for Limb -->
  <joint name="joint_2" type="fixed">
    <parent link="limb_link"/>
    <child link="limb_joint_bottom_blue_link"/>
    <origin xyz="0 0 0.09" rpy="0 0 0"/>
  </joint>


  <!-- Limb Joint Bottom -->
  <link name="limb_joint_bottom_blue_link">
    <visual>
      <geometry>
        <sphere radius="0.03125"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.03125"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.5"/>
    <inertia ixx="0.00098" ixy="0.0" ixz="0.0" iyy="0.00098" iyz="0.0" izz="0.00098"/>
    </inertial>
  </link>
  
</robot>


