<?xml version="1.0"?>
<robot name="Limb_LINK">


<link name="">
    <visual>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 55.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.004"/>
      <inertia ixx="1.7e-07" ixy="0.0" ixz="0.0"
      iyy="1.7e-07" iyz="0.0"
      izz="1.7e-07"/>
    </inertial>
  </link>



    <joint name="joint_1" type="fixed">
    <parent link="aux_sphere"/>
    <child link="limb_link"/>
    <origin xyz="0 0 0.033" rpy="0 0 3.15"/>
  </joint>

   <!-- Limb Link -->
  <link name="limb_link">

    <visual>
      <geometry>
        <cylinder length="0.0575" radius="0.015"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.0575" radius="0.015"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
    <inertia ixx="6.875e-06" ixy="0.0" ixz="0.0"
    iyy="6.875e-06" iyz="0.0"
    izz="5.625e-06"/>   
    </inertial>
  </link>


    

   <!-- Joint for Limb -->
  <joint name="joint_2" type="fixed">
    <parent link="limb_link"/>
    <child link="limb_joint_bottom_blue_link"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
  </joint>


  <!-- Limb Joint Bottom -->
  <link name="limb_joint_bottom_blue_link">
    <visual>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.006"/>
    <inertia ixx="0.00098" ixy="0.0" ixz="0.0" iyy="0.00098" iyz="0.0" izz="0.00098"/>
    </inertial>
  </link>
  
</robot>


