<?xml version="1.0"?>
<robot name="Link:small">



<link name="">
    <visual>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 55.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.004"/>
    <inertia ixx="1.7e-07" ixy="0.0" ixz="0.0"
      iyy="1.7e-07" iyz="0.0"
      izz="1.7e-07"/>
    </inertial>
  </link>



    <joint name="joint_1" type="fixed">
    <parent link="a"/>
    <child link="limb_link"/>
    <origin xyz="0 0 0.022" rpy="0 0 3.15"/>
  </joint>


  <link name="limb_link">
    <visual>
      <geometry>
        <cylinder length="0.045" radius="0.015"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.045" radius="0.015"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
    <inertia ixx="6.875e-06" ixy="0.0" ixz="0.0"
    iyy="6.875e-06" iyz="0.0"
    izz="5.625e-06"/>   
    </inertial>
    </link>



  <!-- Joint for Limb -->
  <joint name="joint_2" type="fixed">
    <parent link="limb_link"/>
    <child link="limb_small_link_robot"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>



<link name="limb_small_link_robot">
    <visual>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.006"/>
    <inertia ixx="0.00098" ixy="0.0" ixz="0.0" iyy="0.00098" iyz="0.0" izz="0.00098"/>
    </inertial>
  </link>



</robot>

