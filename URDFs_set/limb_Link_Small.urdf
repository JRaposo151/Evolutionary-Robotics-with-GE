<?xml version="1.0"?>
<robot name="Link:small">



<link name="">
    <visual>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 55.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0025" ixy="0.0" ixz="0.0" iyy="0.0025" iyz="0.0" izz="0.0025"/>
    </inertial>
  </link>



    <joint name="joint_1" type="fixed">
    <parent link="a"/>
    <child link="limb_link"/>
    <origin xyz="0 0 0.045" rpy="0 0 3.15"/>
  </joint>


  <link name="limb_link">
    <visual>
      <geometry>
        <cylinder length="0.10" radius="0.02125"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>

    <visual>
      <origin xyz="0.02125 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.003 0.003 0.10"/>
      </geometry>
      <material name="red_line">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.1875" radius="0.02125"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.0125" ixy="0.0" ixz="0.0" iyy="0.0125" iyz="0.0" izz="0.0125"/>
    </inertial>
  </link>



  <!-- Joint for Limb -->
  <joint name="joint_2" type="fixed">
    <parent link="limb_link"/>
    <child link="limb_small_link_robot"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>



<link name="limb_small_link_robot">
    <visual>
      <geometry>
        <sphere radius="0.02125"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02125"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.0125" ixy="0.0" ixz="0.0" iyy="0.0125" iyz="0.0" izz="0.0125"/>
    </inertial>
  </link>



</robot>

