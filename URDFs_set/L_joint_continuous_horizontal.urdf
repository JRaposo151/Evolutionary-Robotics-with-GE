<?xml version="1.0"?>
<robot name="L_JOINT_CONT_HZ">

<joint name="joint_1" type="revolute">
    <parent link=""/>
    <child link="auxiliar"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1000" upper="1000" effort="1.0" velocity="1.0" rpy="0 3.15 0" />
  </joint>

  <link name="auxiliar">
    <visual>
      <geometry>
        <cylinder length="0.06" radius="0.04"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.06" radius="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.00035" ixy="0.0" ixz="0.0" iyy="0.00035" iyz="0.0" izz="0.00040"/>
      </inertial>
  </link>

   <joint name="joint_2" type="fixed">
    <parent link="auxiliar"/>
    <child link=""/>
    <origin xyz="0.04 0 0.025" rpy="0 1.6 0"/>
  </joint>

</robot>