    </collision>
    <inertial>
      <mass value="0.5" />
      <inertia ixx="0.041666666666666664" ixy="0.0" ixz="0.0" iyy="0.041666666666666664" iyz="0.0" izz="0.041666666666666664" />
    </inertial>
