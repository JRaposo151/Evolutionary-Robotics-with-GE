  <!-- Bottom Sphere -->
  <joint name="bottom_sphere_joint_body2" type="fixed">
    <parent link="body_link"/>
    <child link="bottom_sphere"/>
    <origin xyz="0 0 -0.05" rpy="0 0 0"/>
  </joint>
  <link name="bottom_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0025" ixy="0.0" ixz="0.0" iyy="0.0025" iyz="0.0" izz="0.0025"/>
    </inertial>
  </link>


 