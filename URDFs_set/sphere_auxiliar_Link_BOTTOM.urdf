<?xml version="1.0"?>
<robot name="BODY_jointFixed_Bottom">

<!-- Bottom Sphere -->
  <joint name="joint_1" type="fixed">
    <parent link="body_link"/>
    <child link="bottom_sphere"/>
    <origin xyz="0 0 -0.05" rpy="0 0 0"/>
  </joint>

  <link name="bottom_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.00008" ixy="0.0" ixz="0.0" iyy="0.00008" iyz="0.0" izz="0.00008"/>
    </inertial>
  </link>
  </robot>

 