<?xml version="1.0"?>
<robot name="L_JOINT_CONTI">


<joint name="joint_1" type="continuous">
    <parent link=""/>
    <child link="auxiliar"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="auxiliar">
    <visual>
      <geometry>
        <cylinder length="0.07" radius="0.04"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.07" radius="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0025" ixy="0.0" ixz="0.0" iyy="0.0025" iyz="0.0" izz="0.0025"/>
    </inertial>
  </link>

   <joint name="joint_2" type="fixed">
    <parent link="auxiliar"/>
    <child link=""/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  
  </robot>