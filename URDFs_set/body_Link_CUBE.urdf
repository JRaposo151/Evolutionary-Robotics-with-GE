<?xml version="1.0"?>
<robot name="BODY_LINK">
  <!-- Body Link with Cube -->
  <link name="body_link">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.1"/> <!-- Cube with 10cm sides -->
      </geometry>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.025" ixy="0.0" ixz="0.0" iyy="0.025" iyz="0.0" izz="0.025"/>
    </inertial>
  </link>

  <!-- Joints with black spheres at each face of the cube -->
  <joint name="top_sphere_joint_body" type="fixed">
    <parent link="body_link"/>
    <child link="top_sphere"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>
  <link name="top_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="bottom_sphere_joint_body" type="fixed">
    <parent link="body_link"/>
    <child link="bottom_sphere"/>
    <origin xyz="0 0 -0.05" rpy="0 0 0"/>
  </joint>
  <link name="bottom_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="front_sphere_joint_body" type="fixed">
    <parent link="body_link"/>
    <child link="front_sphere"/>
    <origin xyz="0 0.05 0" rpy="0 0 0"/>
  </joint>
  <link name="front_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="back_sphere_joint_body" type="fixed">
    <parent link="body_link"/>
    <child link="back_sphere"/>
    <origin xyz="0 -0.05 0" rpy="0 0 0"/>
  </joint>
  <link name="back_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="left_sphere_joint_body" type="fixed">
    <parent link="body_link"/>
    <child link="left_sphere"/>
    <origin xyz="-0.05 0 0" rpy="0 0 0"/>
  </joint>
  <link name="left_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="right_sphere_joint_body" type="fixed">
    <parent link="body_link"/>
    <child link="right_sphere"/>
    <origin xyz="0.05 0 0" rpy="0 0 0"/>
  </joint>
  <link name="right_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>
</robot>
