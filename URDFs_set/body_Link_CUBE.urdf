<?xml version="1.0"?>
<robot name="BODY_LINK">
  <!-- Body Link with Cube -->
  <link name="body_link">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.1"/> <!-- Cube with 10cm sides -->
      </geometry>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.00833" ixy="0.0" ixz="0.0" iyy="0.00833" iyz="0.0" izz="0.00833"/>   
     </inertial>
  </link>


</robot>
