<?xml version="1.0"?>
<robot name="B_JOINT_REVO">

<joint name="joint_1" type="revolute">
    <parent link=""/>
    <child link="auxiliar"/>
    <origin xyz="0 0 0" rpy="1.55 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1" upper="1" effort="1.0" velocity="1.0"/>
  </joint>


  <link name="auxiliar">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.04" radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
          <mass value="0.05" /> <!-- Mass of the link -->
  <inertia 
    ixx="7.5e-06" ixy="0.0" ixz="0.0"
    iyy="7.5e-06" iyz="0.0"
    izz="7.5e-06" />
  </inertial>
  </link>


  <joint name="joint_2" type="fixed">
    <parent link="auxiliar"/>
    <child link="bottom_sphere"/>
    <origin xyz="0 0.02 0" rpy="0 0 0"/>
  </joint>

  <link name="extra_sphere">
    <visual>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.004"/>
      <inertia ixx="1.7e-07" ixy="0.0" ixz="0.0"
      iyy="1.7e-07" iyz="0.0"
      izz="1.7e-07"/>
    </inertial>
  </link>

  <joint name="joint_3" type="fixed">
    <parent link="bottom_sphere"/>
    <child link=""/>
    <!-- Adjust the origin so that Cube2 is offset relative to its left sphere -->
    <origin xyz="0 0.025 0" rpy="0 0 0"/>
  </joint>

</robot>