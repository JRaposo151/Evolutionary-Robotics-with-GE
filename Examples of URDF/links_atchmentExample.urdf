<?xml version="1.0"?>
<robot name="Link:small">



<link name="aux_sphere">
    <visual>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 55.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0025" ixy="0.0" ixz="0.0" iyy="0.0025" iyz="0.0" izz="0.0025"/>
    </inertial>
  </link>



    <joint name="joint_1" type="fixed">
    <parent link="aux_sphere"/>
    <child link="limb_link"/>
    <origin xyz="0 0 0.045" rpy="0 0 0"/>
  </joint>


   <!-- Limb Link -->
  <link name="limb_link">
    <visual>
      <geometry>
        <cylinder length="0.10" radius="0.02125"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.1875" radius="0.02125"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.0125" ixy="0.0" ixz="0.0" iyy="0.0125" iyz="0.0" izz="0.0125"/>
    </inertial>
  </link>



  <!-- Joint for Limb -->
  <joint name="joint_2" type="fixed">
    <parent link="limb_link"/>
    <child link="limb_small_link_robot"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>



<link name="limb_small_link_robot">
    <visual>
      <geometry>
        <sphere radius="0.02125"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02125"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.0125" ixy="0.0" ixz="0.0" iyy="0.0125" iyz="0.0" izz="0.0125"/>
    </inertial>
  </link>
<!-- Tudo em cima e tudo um link só -->


<joint name="joint_1" type="continuous">
    <parent link="limb_small_link_robot"/>
    <child link="auxiliar"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="auxiliar">
    <visual>
      <geometry>
        <cylinder length="0.07" radius="0.04"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.07" radius="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0025" ixy="0.0" ixz="0.0" iyy="0.0025" iyz="0.0" izz="0.0025"/>
    </inertial>
  </link>

   <joint name="joint_2" type="fixed">
    <parent link="auxiliar"/>
    <child link="aux_sphere2"/>
    <origin xyz="0 0 0" rpy="0 1.6 0"/>
  </joint>

<!-- Limb Link -->
<link name="aux_sphere2">
    <visual>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 55.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0025" ixy="0.0" ixz="0.0" iyy="0.0025" iyz="0.0" izz="0.0025"/>
    </inertial>
  </link>



    <joint name="joint_1" type="fixed">
    <parent link="aux_sphere2"/>
    <child link="limb_link2"/>
    <origin xyz="0 0 0.045" rpy="0 0 0"/>
  </joint>


   
  <link name="limb_link2">
    <visual>
      <geometry>
        <cylinder length="0.10" radius="0.02125"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.1875" radius="0.02125"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.0125" ixy="0.0" ixz="0.0" iyy="0.0125" iyz="0.0" izz="0.0125"/>
    </inertial>
  </link>



  <!-- Joint for Limb -->
  <joint name="joint_2" type="fixed">
    <parent link="limb_link2"/>
    <child link="limb_small_link_robot2"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>



<link name="limb_small_link_robot2">
    <visual>
      <geometry>
        <sphere radius="0.02125"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02125"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.5"/>
      <inertia ixx="0.0125" ixy="0.0" ixz="0.0" iyy="0.0125" iyz="0.0" izz="0.0125"/>
    </inertial>
  </link>
</robot>
