<?xml version="1.0"?>
<robot name="BODY_LINK">
  <!-- Body Link with Cube -->
  <link name="body_link">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.1"/> <!-- Cube with 10cm sides -->
      </geometry>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.025" ixy="0.0" ixz="0.0" iyy="0.025" iyz="0.0" izz="0.025"/>
    </inertial>
  </link>
  
  <joint name="back_sphere_joint" type="fixed">
    <parent link="body_link"/>
    <child link="back_sphere"/>
    <origin xyz="0 -0.05 0" rpy="0 1.55 0"/>
  </joint>
  <link name="back_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0025" ixy="0.0" ixz="0.0" iyy="0.0025" iyz="0.0" izz="0.0025"/>
    </inertial>
  </link>

<joint name="revolute_joint" type="revolute">
    <parent link="back_sphere"/>
    <child link="auxiliar"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="1.0" velocity="1.0"/>
  </joint>


  <link name="auxiliar">
    <visual>
      <geometry>
        <cylinder length="0.07" radius="0.05"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0025" ixy="0.0" ixz="0.0" iyy="0.0025" iyz="0.0" izz="0.0025"/>
    </inertial>
  </link>



  <joint name="fixed_joint" type="fixed">
    <parent link="auxiliar"/>
    <child link="bottom_sphere"/>
    <origin xyz="0 -0.05 0" rpy="0 0 0"/>
  </joint>

  <link name="bottom_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0025" ixy="0.0" ixz="0.0" iyy="0.0025" iyz="0.0" izz="0.0025"/>
    </inertial>
  </link>

  <joint name="cube2_connection_joint" type="fixed">
    <parent link="bottom_sphere"/>
    <child link="body_link2"/>
    <!-- Adjust the origin so that Cube2 is offset relative to its left sphere -->
    <origin xyz="0 -0.05 0" rpy="0 0 0"/>
  </joint>




<!-- ================= Cube 2 (Body Link 2) ================= -->
  <link name="body_link2">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.025" ixy="0" ixz="0" iyy="0.025" iyz="0" izz="0.025"/>
    </inertial>
  </link>


</robot>