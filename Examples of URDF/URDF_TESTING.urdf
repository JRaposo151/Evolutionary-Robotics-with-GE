<?xml version="1.0"?>
<robot name="BODY_LINK">
  <!-- Body Link with Cube -->
  <link name="body_link">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.1"/> <!-- Cube with 10cm sides -->
      </geometry>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.025" ixy="0.0" ixz="0.0" iyy="0.025" iyz="0.0" izz="0.025"/>
    </inertial>
  </link>
  
   <joint name="joint_1" type="fixed">
    <parent link="body_link"/>
    <child link="front_sphere"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <link name="front_sphere">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0025" ixy="0.0" ixz="0.0" iyy="0.0025" iyz="0.0" izz="0.0025"/>
    </inertial>
  </link>


  <joint name="joint_1" type="fixed">
    <parent link="front_sphere"/>
    <child link="link_square"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
<link name="link_square">
  <visual>
    <geometry>
      <box size="0.07 0.07 0.07" /> <!-- Length, width, and height of the box -->
    </geometry>
    <material name="blue">
      <color rgba="0.0 0.0 0.0 1.0" /> <!-- RGBA color for the link -->
    </material>
  </visual>
  <collision>
    <geometry>
      <box size="0.07 0.07 0.07" /> <!-- Same dimensions as the visual -->
    </geometry>
  </collision>
  <inertial>
    <mass value="1.0" /> <!-- Mass of the link -->
    <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.003" /> <!-- Moment of inertia -->
  </inertial>
</link>


  <joint name="joint_2" type="fixed">
    <parent link="link_square"/>
    <child link="body_link2"/>
    <origin xyz="0 0 0.07" rpy="0 0 0"/>
  </joint>





<!-- ================= Cube 2 (Body Link 2) ================= -->
    <link name="body_link2">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.1"/> <!-- Cube with 10cm sides -->
      </geometry>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.025" ixy="0.0" ixz="0.0" iyy="0.025" iyz="0.0" izz="0.025"/>
    </inertial>
  </link>


</robot>